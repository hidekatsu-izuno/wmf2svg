prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "worktree"], decision="allow")
prefix_rule(pattern=["mvn", "-q", "verify"], decision="allow")
prefix_rule(pattern=["mvn", "-q", "test"], decision="allow")
prefix_rule(pattern=["mvn", "-q", "spotless:apply"], decision="allow")
prefix_rule(pattern=["gh", "issue", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["powershell.exe", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "./src/test/bin/wmf2png.ps1"], decision="allow")

